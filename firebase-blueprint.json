{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "preferredCurrency": { "type": "string", "enum": ["IQD"] }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income or Expense record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "currency": { "type": "string", "enum": ["IQD"] },
        "category": { "type": "string" },
        "note": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "receiptUrl": { "type": "string" }
      },
      "required": ["userId", "type", "amount", "currency", "date"]
    },
    "Debt": {
      "title": "Debt",
      "description": "Money lent or borrowed",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "personName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "enum": ["IQD"] },
        "type": { "type": "string", "enum": ["lent", "borrowed"] },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      },
      "required": ["userId", "personName", "amount", "currency", "type", "status", "date"]
    },
    "SavingGoal": {
      "title": "Saving Goal",
      "description": "Financial goals to save for",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "goalName": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "currency": { "type": "string", "enum": ["IQD"] },
        "deadline": { "type": "string", "format": "date-time" },
        "icon": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "goalName", "targetAmount", "currentAmount", "currency", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's income and expense records"
    },
    "users/{userId}/debts/{debtId}": {
      "schema": "Debt",
      "description": "User's debt records"
    },
    "users/{userId}/savings/{savingId}": {
      "schema": "SavingGoal",
      "description": "User's savings goals"
    }
  }
}
